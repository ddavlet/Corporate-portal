# Copy this file to production `.env` and adjust domains/paths if needed.
# These variables control Traefik rules for frontend, backend_v2, and root redirect.

# --- FRONTEND ---
# Tenant domains that should serve frontend_v2.
TRAEFIK_FRONTEND_HOST_RULE=Host(`qulay.kolberg.uz`)||Host(`main.kolberg.uz`)||Host(`lemonfit.kolberg.uz`)||Host(`lemonaqua.kolberg.uz`)||Host(`neuron.kolberg.uz`)
# Path rule for frontend app routes.
TRAEFIK_FRONTEND_APP_PATH_RULE=PathPrefix(`/app/`)||PathPrefix(`/app`)

# --- BACKEND V2 ---
# Tenant domains for generic backend API router.
TRAEFIK_BACKEND_V2_HOST_RULE=Host(`qulay.kolberg.uz`)||Host(`main.kolberg.uz`)||Host(`lemonfit.kolberg.uz`)||Host(`lemonaqua.kolberg.uz`)||Host(`neuron.kolberg.uz`)
# API rule excluding n8n integration and messaging gateway paths.
TRAEFIK_BACKEND_V2_API_PATH_RULE=PathPrefix(`/api`)&& !PathPrefix(`/api/n8n/`)&& !PathPrefix(`/api/messaging-gateway/`)
# Dedicated backend n8n integration rule.
TRAEFIK_BACKEND_V2_N8N_RULE=(Host(`qulay.kolberg.uz`)||Host(`main.kolberg.uz`)||Host(`lemonfit.kolberg.uz`)||Host(`lemonaqua.kolberg.uz`)||Host(`neuron.kolberg.uz`))&& PathPrefix(`/api/n8n/`)
