              "value": "={\n    \"Поставщик\": {\n      \"type\": \"string\",\n    },\n    \"Категория расхода\": {\n      \"type\": \"string\",\n    },\n    \"Сумма\": {\n      \"type\": \"number\",\n    },\n    \"Валюта\": {\n      \"type\": \"string\",\n      \"enum\": [\"UZS\", \"USD\"]\n    },\n    \"Тип оплаты\": {\n      \"type\": \"string\",\n    },\n    \"Назначение платежа\": {\n      \"type\": \"string\",\n    },\n    \"Описание/зачем\": {\n      \"type\": \"string\",\n    },\n    \"Срочность\": {\n      \"type\": \"string\",\n      \"enum\": [\"Обычно\", \"Срочно\"]\n    },\n    \"Заявитель\": {\n      \"type\": \"string\" or \"int\"\n    }\n}",
